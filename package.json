{
  "name": "mcp-framework-library",
  "version": "0.1.0",
  "description": "MCP server providing framework API documentation for AI agents",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "node --test",
    "lint": "eslint src/",
    "init-db": "node scripts/init_db.js",
    "clean": "rm -rf dist node_modules data/*.db",
    "release": "npm run build && npm run test"
  },
  "keywords": [
    "mcp",
    "framework",
    "documentation",
    "ai",
    "fastapi",
    "react",
    "vue",
    "django",
    "express",
    "code-generation"
  ],
  "author": "sunhanjun0",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^9.4.3",
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  }
}
